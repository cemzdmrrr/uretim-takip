# TexPilot - Prodüksiyon Ortam Yapılandırması
# Bu dosyayı .env.production olarak kopyalayın ve gerçek değerleri girin.
# .env.production dosyası git'e dahil EDİLMEZ.
#
# Web build:
#   .\scripts\build_web.ps1 -Env production
#
# Geliştirme ortamı için .env dosyasını kullanın.

# ============================================
# Supabase Yapılandırması
# ============================================
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_production_anon_key

# UYARI: Service role key prodüksiyon istemci build'lerinde KULLANILMAMALIDIR!
# Edge function'lar SUPABASE_SERVICE_ROLE_KEY'i kendi ortam değişkenlerinden alır.
# SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# Uygulama Yapılandırması
# ============================================
APP_ENV=production
APP_URL=https://app.texpilot.com

# ============================================
# Ödeme Entegrasyonu (iyzico)
# ============================================
# IYZICO_API_KEY=your_iyzico_api_key
# IYZICO_SECRET_KEY=your_iyzico_secret_key
# IYZICO_BASE_URL=https://api.iyzipay.com
